# Port Render will assign automatically. Keep this for local development only.
PORT=3001

# Same contract deployed in GenLayer Studio
CONTRACT_ADDRESS=0xa3b7C6E1454cb11a243B2a5dDb05161d725f08E1

# GenLayer RPC endpoint
GENLAYER_RPC_URL=https://studio.genlayer.com/api

# Server-side admin signer
ADMIN_PRIVATE_KEY=0xYOUR_ADMIN_PRIVATE_KEY

# Bearer token required by the admin API
ADMIN_API_TOKEN=replace-with-a-long-random-token

# Comma-separated frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
