# Copy this file to .env and fill in your values

# Deployed contract address from GenLayer Studio
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional Render backend URL for safe server-side signing
VITE_BACKEND_URL=https://your-render-service.onrender.com

# Optional local-only fallback signer. Do not use this in Vercel.
VITE_ADMIN_PRIVATE_KEY=

# GenLayer RPC endpoint
VITE_GENLAYER_RPC_URL=https://studio.genlayer.com/api
